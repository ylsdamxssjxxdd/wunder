{
  "mcp": {
    "transport": "streamable-http",
    "host": "0.0.0.0",
    "port": 9010
  },
  "database": {
    "default_key": "local_hr_mysql",
    "description": "公司全量人员信息数据库（50000人）",
    "export_root": "exports/extra_mcp",
    "targets": {
      "local_hr_mysql": {
        "type": "mysql",
        "host": "127.0.0.1",
        "port": 3307,
        "user": "root",
        "password": "rootpass123!",
        "database": "hr_promotion_sim",
        "connect_timeout": 8,
        "description": "本地 MySQL 演示库（人力资源晋升场景）"
      }
    },
    "tables": {
      "company_all_personnel": {
        "table": "人员信息",
        "description": "公司所有人员信息（全量50000），用于让模型自主筛选符合晋升条件的人选"
      }
    }
  },
  "knowledge": {
    "enabled": false,
    "base_url": "http://127.0.0.1:9380",
    "api_key": "REPLACE_WITH_RAGFLOW_API_KEY",
    "default_key": "product_docs",
    "request": {
      "top_k": 8,
      "similarity_threshold": 0.2,
      "highlight": true
    },
    "targets": {
      "product_docs": {
        "dataset_ids": [
          "REPLACE_WITH_PRODUCT_DATASET_ID_1",
          "REPLACE_WITH_PRODUCT_DATASET_ID_2"
        ],
        "description": "产品文档知识库示例，演示一个知识库目标聚合多个 dataset_ids"
      },
      "hr_docs": {
        "dataset_ids": [
          "REPLACE_WITH_HR_DATASET_ID_1",
          "REPLACE_WITH_HR_DATASET_ID_2"
        ],
        "description": "人事制度知识库示例，演示同时配置多个知识库目标"
      }
    }
  }
}
