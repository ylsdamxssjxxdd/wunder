lsp:
  enabled: false
  timeout_s: 0
  diagnostics_debounce_ms: 0
  idle_ttl_s: 0
  servers: []
a2a:
  timeout_s: 120
  services:
  - name: wunder
    endpoint: http://127.0.0.1:18000/a2a
    service_type: internal
    user_id: demo_user
    enabled: false
    allow_self: true
    description: wunder 榛樿 A2A 鏈嶅姟锛岀敤浜庡唴閮ㄥ崗浣?    display_name: Wunder 鍐呴儴
    headers: {}
    auth: null
    agent_card: null
    max_depth: null
    default_method: null
skills:
  paths:
  - /app/config/skills
  - config/data/admin_skills
  enabled:
  - 鍏枃鍐欎綔
  - 娣卞害鐮旂┒
  - 濂冲ú
  - 鎶€鑳藉垱寤哄櫒
knowledge:
  bases:
  - name: 鍏徃鍒跺害鐭ヨ瘑搴?    description: 鍏徃鍒跺害鐭ヨ瘑搴撶ず渚?    root: ./config/knowledge/plan
    enabled: true
    shared: null
    base_type: null
    embedding_model: null
    chunk_size: null
    chunk_overlap: null
    top_k: null
    score_threshold: null
vector_store:
  weaviate:
    url: http://wunder-weaviate:8080
    api_key: ''
    timeout_s: 30
    batch_size: 64
observability:
  log_level: info
  server_log_dir: ./config/data/logs/server
  server_log_retention_days: 14
  monitor_event_limit: 500
  monitor_payload_max_chars: 0
  monitor_drop_event_types:
  - llm_output_delta
  - tool_output_delta
storage:
  backend: postgres
  db_path: ./config/data/wunder.db
  postgres:
    dsn: postgresql://wunder:wunder@wunder-postgres:5432/wunder
    connect_timeout_s: 5
    pool_size: 64
channels:
  enabled: true
  allow_unknown_accounts: true
  session_strategy: main_thread
  default_agent_id: null
  default_tool_overrides: []
  rate_limit:
    default_qps: 5
    default_concurrency: 2
    by_channel: {}
  outbox:
    worker_enabled: true
    poll_interval_ms: 500
    max_batch: 50
    max_retries: 5
    retry_base_s: 2.0
    retry_max_s: 60.0
  media:
    asr:
      enabled: false
      provider: openai
      base_url: https://api.openai.com/v1
      api_key: ''
      model: whisper-1
      timeout_s: 30
      max_bytes: 26214400
    tts:
      enabled: false
      provider: openai
      base_url: https://api.openai.com/v1
      api_key: ''
      model: gpt-4o-mini-tts
      voice: alloy
      format: mp3
      timeout_s: 30
      max_chars: 2000
    ocr:
      enabled: false
      endpoint: ''
      api_key: ''
      timeout_s: 15
      prompt: null
    geocode:
      enabled: false
      endpoint: ''
      api_key: ''
      timeout_s: 10
gateway:
  enabled: true
  auth_token: ''
  protocol_version: 1
  allow_unpaired_nodes: false
  node_token_required: false
  allow_gateway_token_for_nodes: false
  allowed_origins: []
  trusted_proxies: []
sandbox:
  mode: sandbox
  endpoint: http://wunder-sandbox:9001
  container_root: /workspaces
  network: bridge
  readonly_rootfs: true
  idle_ttl_s: 0
  timeout_s: 300
  resources:
    cpu: 8.0
    memory_mb: 8096
    pids: 256
agent_queue:
  enabled: true
  poll_interval_ms: 1500
  max_retries: 2
  task_ttl_s: 86400
user_agents:
  worker_cards_root: ./config/preset_worker_cards
  presets: []
prompt_templates:
  active: default
