{
  "packageName": "wunder\u8865\u5145\u5305",
  "defaultBuildRoot": "temp_dir\\win7-gnu-lab\\win7-supplement",
  "downloadsDir": "downloads",
  "stageDir": "stage",
  "distDir": "dist",
  "layout": {
    "pythonRoot": "opt\\python",
    "gitRoot": "opt\\git",
    "rgRoot": "opt\\rg"
  },
  "python": {
    "version": "3.8.10",
    "source": "python.org embeddable package",
    "defaultPackageIndexUrl": "https://pypi.tuna.tsinghua.edu.cn/simple",
    "bootstrap": {
      "getPipUrl": "https://bootstrap.pypa.io/pip/3.8/get-pip.py",
      "pipSpec": "pip<25",
      "setuptoolsSpec": "setuptools<76",
      "wheelSpec": "wheel<0.46"
    },
    "profiles": {
      "minimal": {
        "description": "Base embeddable Python only, without extra third-party packages.",
        "requirementsPath": "",
        "validateImports": []
      },
      "common": {
        "description": "Slim Win7-friendly common package set with networking, office/video document IO, fonts, map/weather tooling, database access, and plotting.",
        "requirementsPath": "packaging/python/requirements-win7-common.txt",
        "validateImports": [
          "requests",
          "numpy",
          "pandas",
          "openpyxl",
          "matplotlib",
          "tabulate",
          "PIL",
          "docx",
          "pptx",
          "PyPDF2",
          "xlrd",
          "xlsxwriter",
          "sqlalchemy",
          "pymysql",
          "aiosqlite",
          "lxml.etree",
          "ffmpeg",
          "imageio",
          "imageio_ffmpeg",
          "cv2",
          "folium",
          "pyproj",
          "shapely",
          "netCDF4",
          "cftime",
          "h5py",
          "metpy",
          "seaborn",
          "plotly",
          "pyecharts"
        ],
        "plotProbe": true
      }
    },
    "notes": [
      "Python 3.8 is the last official CPython line that still supports Windows 7.",
      "The embeddable package is used so the supplement archive can be extracted directly into the desktop install directory.",
      "Windows 7 should include KB2533623 and the Universal CRT update for best compatibility.",
      "The default Python package index is the Tsinghua Tuna mirror for more stable Win7 supplement builds in domestic networks; override it with -PythonPackageIndexUrl when needed."
    ],
    "archives": {
      "x64": {
        "fileName": "python-3.8.10-embed-amd64.zip",
        "url": "https://www.python.org/ftp/python/3.8.10/python-3.8.10-embed-amd64.zip"
      },
      "ia32": {
        "fileName": "python-3.8.10-embed-win32.zip",
        "url": "https://www.python.org/ftp/python/3.8.10/python-3.8.10-embed-win32.zip"
      }
    }
  },
  "git": {
    "version": "2.46.2.windows.1",
    "flavor": "MinGit",
    "source": "git-for-windows",
    "notes": [
      "Git for Windows documents 2.46.2 as the last version supporting Windows 7 / 8 / 8.1.",
      "MinGit is intended for embedding into third-party desktop applications and is sufficient for non-interactive git usage."
    ],
    "archives": {
      "x64": {
        "fileName": "MinGit-2.46.2-64-bit.zip",
        "downloadUrl": "https://api.github.com/repos/git-for-windows/git/releases/assets/194599374",
        "url": "https://github.com/git-for-windows/git/releases/download/v2.46.2.windows.1/MinGit-2.46.2-64-bit.zip"
      },
      "ia32": {
        "fileName": "MinGit-2.46.2-32-bit.zip",
        "downloadUrl": "https://api.github.com/repos/git-for-windows/git/releases/assets/194599396",
        "url": "https://github.com/git-for-windows/git/releases/download/v2.46.2.windows.1/MinGit-2.46.2-32-bit.zip"
      }
    }
  },
  "rg": {
    "version": "14.1.1",
    "flavor": "ripgrep official binary",
    "source": "BurntSushi/ripgrep",
    "notes": [
      "ripgrep is bundled as a standalone binary so search_content can use rg without relying on system installation."
    ],
    "archives": {
      "x64": {
        "fileName": "ripgrep-14.1.1-x86_64-pc-windows-msvc.zip",
        "url": "https://github.com/BurntSushi/ripgrep/releases/download/14.1.1/ripgrep-14.1.1-x86_64-pc-windows-msvc.zip"
      },
      "ia32": {
        "fileName": "ripgrep-14.1.1-i686-pc-windows-msvc.zip",
        "url": "https://github.com/BurntSushi/ripgrep/releases/download/14.1.1/ripgrep-14.1.1-i686-pc-windows-msvc.zip"
      }
    }
  }
}
