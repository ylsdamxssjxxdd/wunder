{
  "name": "wunder-frontend",
  "version": "0.3.0",
  "description": "Wunder user frontend",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev-server.mjs",
    "dev:raw": "node ../node_modules/vite/bin/vite.js",
    "build": "node ../node_modules/vite/bin/vite.js build",
    "preview": "node ../node_modules/vite/bin/vite.js preview",
    "typecheck": "npm run typecheck:vue",
    "build:check": "npm run typecheck && node ../node_modules/vite/bin/vite.js build",
    "test:chat-pending": "node ../node_modules/esbuild/bin/esbuild scripts/regression/chat-pending-regression.test.ts --bundle --platform=node --format=cjs --alias:@=./src --outfile=../temp_dir/frontend-tests/chat-pending-regression.cjs && node ../temp_dir/frontend-tests/chat-pending-regression.cjs",
    "test:chat-interactive-runtime-recovery": "node ../node_modules/esbuild/bin/esbuild scripts/regression/chat-interactive-runtime-recovery-regression.test.ts --bundle --platform=node --format=cjs --outfile=../temp_dir/frontend-tests/chat-interactive-runtime-recovery-regression.cjs && node ../temp_dir/frontend-tests/chat-interactive-runtime-recovery-regression.cjs",
