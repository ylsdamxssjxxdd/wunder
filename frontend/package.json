    "test:chat-watchdog-reconcile": "node ../node_modules/esbuild/bin/esbuild scripts/regression/chat-watchdog-reconcile-regression.test.ts --bundle --platform=node --format=cjs --alias:@=./src --outfile=../temp_dir/frontend-tests/chat-watchdog-reconcile-regression.cjs && node ../temp_dir/frontend-tests/chat-watchdog-reconcile-regression.cjs",
    "test:messenger-chat-refresh-recovery": "node ../node_modules/esbuild/bin/esbuild scripts/regression/messenger-chat-refresh-recovery-regression.test.ts --bundle --platform=node --format=cjs --alias:@=./src --outfile=../temp_dir/frontend-tests/messenger-chat-refresh-recovery-regression.cjs && node ../temp_dir/frontend-tests/messenger-chat-refresh-recovery-regression.cjs",
