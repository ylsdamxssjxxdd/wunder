    "test:message-render": "node ../node_modules/esbuild/bin/esbuild scripts/regression/message-render-regression.test.ts --bundle --platform=node --format=cjs --alias:@=./src --outfile=../temp_dir/frontend-tests/message-render-regression.cjs && node ../temp_dir/frontend-tests/message-render-regression.cjs",
