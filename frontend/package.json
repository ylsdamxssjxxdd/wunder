    "test:e2e:beeroom": "playwright test tests/e2e/beeroom-harness.spec.ts",
    "test:e2e:chat-compaction": "playwright test tests/e2e/chat-compaction-harness.spec.ts",
    "test:e2e:chat-bubble-stress": "playwright test tests/e2e/chat-bubble-stress-harness.spec.ts",
    "test:e2e:messenger-heavy-history": "playwright test tests/e2e/messenger-heavy-history-harness.spec.ts",
    "test:e2e:messenger-send-guard": "playwright test tests/e2e/messenger-send-guard-harness.spec.ts",
    "test:e2e:messenger-return-resume": "playwright test tests/e2e/messenger-return-resume-harness.spec.ts",
    "test:e2e:messenger-stability": "npm run test:e2e:messenger-send-guard && npm run test:e2e:messenger-return-resume",
    "typecheck:vue": "node ./scripts/run-vue-tsc.mjs --noEmit",
    "typecheck:ts": "tsc --noEmit",
    "typecheck:api": "tsc -p tsconfig.api-strict.json --pretty false",
    "test:realtime-pulse": "node ../node_modules/esbuild/bin/esbuild scripts/regression/realtime-pulse-regression.test.ts --bundle --platform=node --format=cjs --alias:@=./src --outfile=../temp_dir/frontend-tests/realtime-pulse-regression.cjs && node ../temp_dir/frontend-tests/realtime-pulse-regression.cjs"
  },
