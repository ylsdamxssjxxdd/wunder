{
  "name": "wunder-frontend",
  "version": "0.1.0",
  "description": "Wunder user frontend",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev-server.mjs",
    "dev:raw": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "npm run typecheck:vue",
    "build:check": "npm run typecheck && vite build",
    "test:chat-pending": "tsc -p scripts/regression/tsconfig.json --pretty false && node scripts/regression/dist/scripts/regression/chat-pending-regression.test.js",
    "test:message-render": "tsc -p scripts/regression/tsconfig.json --pretty false && node scripts/regression/dist/scripts/regression/message-render-regression.test.js",
    "typecheck:vue": "vue-tsc --noEmit",
    "typecheck:ts": "tsc --noEmit",
    "typecheck:api": "tsc -p tsconfig.api-strict.json --pretty false",
    "test:realtime-pulse": "tsc -p scripts/regression/tsconfig.json --pretty false && node scripts/regression/dist/scripts/regression/realtime-pulse-regression.test.js"
  },
  "dependencies": {
    "@antv/g6": "^5.0.51",
    "axios": "^1.7.9",
    "echarts": "^5.5.0",
    "element-plus": "^2.8.8",
    "markdown-it": "^14.1.0",
    "pinia": "^2.2.6",
    "three": "^0.164.1",
    "topojson-client": "^3.1.0",
    "vue": "^3.5.25",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "6.0.3",
    "typescript": "^5.7.3",
    "vite": "7.3.0",
    "vue-tsc": "^2.2.0"
  }
}
