    "test:message-stats": "node ../node_modules/esbuild/bin/esbuild scripts/regression/message-stats-regression.test.ts --bundle --platform=node --format=cjs --outfile=../temp_dir/frontend-tests/message-stats-regression.cjs && node ../temp_dir/frontend-tests/message-stats-regression.cjs",
    "test:message-conversation-retention": "node ../node_modules/esbuild/bin/esbuild scripts/regression/message-conversation-retention-regression.test.ts --bundle --platform=node --format=cjs --outfile=../temp_dir/frontend-tests/message-conversation-retention-regression.cjs && node ../temp_dir/frontend-tests/message-conversation-retention-regression.cjs",
