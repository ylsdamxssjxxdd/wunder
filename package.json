{
  "name": "wunder-workspace",
  "private": true,
  "workspaces": [
    "frontend",
    "desktop/electron"
  ],
  "scripts": {
    "sync:app-version": "python scripts/sync_app_version.py",
    "build:frontend": "npm run build --workspace wunder-frontend",
    "typecheck:frontend": "npm run typecheck --workspace wunder-frontend",
    "prepare:desktop:resources": "npm run prepare:resources --workspace wunder-desktop-electron",
    "build:desktop:linux:x64": "npm run build:linux:x64 --workspace wunder-desktop-electron",
    "build:desktop:linux:arm64": "npm run build:linux:arm64 --workspace wunder-desktop-electron"
  }
}
