    "build:desktop:win7:gnu:x64:with-supplement": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile common",
    "build:desktop:win7:gnu:x64:with-supplement:common": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile common",
    "build:desktop:win7:gnu:x64:with-supplement:minimal": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile minimal",
    "build:desktop:win7:gnu:x64:installer-only": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64",
    "build:desktop:win7:gnu:x64:installer-only:fast": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -SkipBootstrap",
    "build:desktop:win7:gnu:x64:static": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -StaticRuntime",
    "build:desktop:win7:gnu:x64:static:fast": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -StaticRuntime -SkipBootstrap"
  }
}
