{
  "name": "wunder-workspace",
  "private": true,
  "workspaces": [
    "frontend",
    "desktop/electron"
  ],
  "scripts": {
    "sync:app-version": "python scripts/sync_app_version.py",
    "build:frontend": "npm run build --workspace wunder-frontend",
    "typecheck:frontend": "npm run typecheck --workspace wunder-frontend",
    "prepare:desktop:resources": "npm run prepare:resources --workspace wunder-desktop-electron",
    "build:desktop:linux:x64": "npm run build:linux:x64 --workspace wunder-desktop-electron",
    "build:desktop:linux:arm64": "npm run build:linux:arm64 --workspace wunder-desktop-electron",
    "build:desktop:win7:supplement": "powershell -ExecutionPolicy Bypass -File packaging/windows/scripts/build_win7_desktop_supplement.ps1 -Arch ia32 -PythonProfile common",
    "build:desktop:win7:supplement:minimal": "powershell -ExecutionPolicy Bypass -File packaging/windows/scripts/build_win7_desktop_supplement.ps1 -Arch ia32 -PythonProfile minimal",
    "build:desktop:win7:supplement:common": "powershell -ExecutionPolicy Bypass -File packaging/windows/scripts/build_win7_desktop_supplement.ps1 -Arch ia32 -PythonProfile common",
    "build:desktop:win7:supplement:x64": "powershell -ExecutionPolicy Bypass -File packaging/windows/scripts/build_win7_desktop_supplement.ps1 -Arch x64 -PythonProfile common",
    "build:desktop:win7:supplement:x64:minimal": "powershell -ExecutionPolicy Bypass -File packaging/windows/scripts/build_win7_desktop_supplement.ps1 -Arch x64 -PythonProfile minimal",
    "build:desktop:win7:supplement:x64:common": "powershell -ExecutionPolicy Bypass -File packaging/windows/scripts/build_win7_desktop_supplement.ps1 -Arch x64 -PythonProfile common",
    "build:desktop:win7:supplement:ia32": "powershell -ExecutionPolicy Bypass -File packaging/windows/scripts/build_win7_desktop_supplement.ps1 -Arch ia32 -PythonProfile common",
    "build:desktop:win7:supplement:ia32:minimal": "powershell -ExecutionPolicy Bypass -File packaging/windows/scripts/build_win7_desktop_supplement.ps1 -Arch ia32 -PythonProfile minimal",
    "build:desktop:win7:supplement:ia32:common": "powershell -ExecutionPolicy Bypass -File packaging/windows/scripts/build_win7_desktop_supplement.ps1 -Arch ia32 -PythonProfile common",
    "setup:desktop:win7:gnu": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/setup-win7-gnu-toolchain.ps1 -Arch ia32",
    "doctor:desktop:win7:gnu": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/setup-win7-gnu-toolchain.ps1 -Arch ia32 -Doctor",
    "build:desktop:win7:gnu": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch ia32 -BuildSupplement -SupplementPythonProfile common",
    "build:desktop:win7:gnu:fast": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch ia32 -BuildSupplement -SupplementPythonProfile common -SkipBootstrap",
    "setup:desktop:win7:gnu:ia32": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/setup-win7-gnu-toolchain.ps1 -Arch ia32",
    "doctor:desktop:win7:gnu:ia32": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/setup-win7-gnu-toolchain.ps1 -Arch ia32 -Doctor",
    "build:desktop:win7:gnu:ia32": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch ia32 -BuildSupplement -SupplementPythonProfile common",
    "build:desktop:win7:gnu:ia32:fast": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch ia32 -BuildSupplement -SupplementPythonProfile common -SkipBootstrap",
    "setup:desktop:win7:gnu:x64": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/setup-win7-gnu-toolchain.ps1 -Arch x64",
    "doctor:desktop:win7:gnu:x64": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/setup-win7-gnu-toolchain.ps1 -Arch x64 -Doctor",
    "build:desktop:win7:gnu:x64": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile common",
    "build:desktop:win7:gnu:x64:fast": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile common -SkipBootstrap",
    "build:desktop:win7:gnu:x64:release": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile common",
    "build:desktop:win7:gnu:x64:release:common": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile common",
    "build:desktop:win7:gnu:x64:release:minimal": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile minimal",
    "build:desktop:win7:gnu:x64:release:fast": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile common -SkipBootstrap",
    "build:desktop:win7:gnu:x64:release:fast:common": "powershell -ExecutionPolicy Bypass -File desktop/electron/scripts/build-win7-gnu.ps1 -Arch x64 -BuildSupplement -SupplementPythonProfile common -SkipBootstrap",
